# Copy to server/.env and fill in. That file is gitignored; this one is not, so
# never put a real secret here.
#
#     cp server/.env.template server/.env
#
# See the readme for where each value comes from.


# ─── Supabase ────────────────────────────────────────────────────────────────
# Project Settings -> Data API, and Project Settings -> API Keys.

# https://<project-ref>.supabase.co
SUPABASE_URL=

# The publishable / anon key. Safe to send to the browser — the app serves it
# from /api/config so supabase-js can sign users in.
SUPABASE_KEY=

# The service_role key. SERVER ONLY. It bypasses every access rule, and it is
# what lets the app mint a one-time sign-in token without emailing anybody.
# Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string. Project Settings -> Database -> Connection string
# -> URI, with [YOUR-PASSWORD] substituted. Use the pooled (Supavisor) host,
# port 6543 — the app already sets statement_cache_size=0 for pgbouncer.
# postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=


# ─── Speech (Gradium) ────────────────────────────────────────────────────────
# One key for both STT and TTS — https://gradium.ai
GRADIUM_API_KEY=


# ─── LLM ─────────────────────────────────────────────────────────────────────
# Only the provider your personas name is required. Both shipped personas use
# OpenRouter, so OPENROUTER_API_KEY is the one you need.
# Gradbot speaks the OpenAI wire protocol and nothing else — see personas.py.

# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# https://platform.openai.com/api-keys — only if a persona sets llm.provider=openai
OPENAI_API_KEY=


# ─── App ─────────────────────────────────────────────────────────────────────

# 'local' or 'online'. Recorded on every session row so you can tell dev calls
# from real ones.
DEPLOY_ENV=local

# Concurrent calls allowed before /start-session answers 429.
MAX_SESSIONS=5
